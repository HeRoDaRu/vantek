    "helmet": "^8.2.0",
    "nodemailer": "^9.0.1",
    "puppeteer": "^25.2.1",
    "tsconfig-paths": "^4.2.0",
    "uuid": "^14.0.1",
    "zod": "^4.4.3"
  },
