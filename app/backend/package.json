    "@types/better-sqlite3": "^7.6.13",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/nodemailer": "^8.0.1",
    "@types/uuid": "^11.0.0",
    "tsc-alias": "^1.8.17",
